# Copy this file to .env and fill in your own AWS credentials.
# The real .env file is gitignored and must never be committed.
#
# Required AWS permissions:
#   - bedrock:InvokeModel (for Claude summarization)
#   - textract:* (for OCR)
#   - comprehendmedical:* (for SNOMED CT + clinical entity extraction)

AWS_ACCESS_KEY_ID=your-aws-access-key-id-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key-here
AWS_REGION=us-east-1
